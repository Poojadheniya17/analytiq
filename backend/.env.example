# backend/.env — copy this to .env and fill in real values
# NEVER commit .env to GitHub

# ── Environment ────────────────────────────────────────────
ENV=development
# Set to "production" when deployed

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# ── Database ──────────────────────────────────────────────
# Leave empty for SQLite (development)
# Set to PostgreSQL URL for production:
# DATABASE_URL=postgresql://username:password@host:5432/analytiq
DATABASE_URL=

# ── Redis (for background jobs) ───────────────────────────
# Leave empty to skip background jobs (sync mode)
# Set for production:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# ── AI ────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ── Storage ───────────────────────────────────────────────
# Leave empty to use local disk (development)
# Set for production:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=analytiq-data

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Monitoring ────────────────────────────────────────────
# Get free DSN from sentry.io
SENTRY_DSN=
